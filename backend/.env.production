# Production settings
NODE_ENV=production
PORT=3000
CLIENT_URL=https://your-domain.com
DATABASE_PATH=./data/cheapbasket_prod.db

# Features configuration
AUTH_ENABLED=true
ADS_ENABLED=true

# Secrets
# MUST BE DEFINED IN PRODUCTION ENVIRONMENT
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
JWT_SECRET=${JWT_SECRET}

# Auto-scraping Configuration
AUTO_SCRAPE_ENABLED=true
AUTO_SCRAPE_INTERVAL_HOURS=12
AUTO_SCRAPE_TERMS=csirkemell,tej,tojás,rizs,kenyér
